---
const pathname = new URL(Astro.request.url).pathname;

const links = [
  { href: "/", label: "Works" },
  { href: "/about", label: "About" },
];
const linkActive =
  "underline decoration-4 decoration-primary-500 underline-offset-4";
const linkInactive = "hover:no-underline";

function setActiveClass(link: Record<string, string>) {
  return link.href === pathname ? linkActive : linkInactive;
}
---

<header class="sticky top-0 z-10 bg-surface-50-950/90 backdrop-blur-md p-4">
  <div
    class="container mx-auto grid grid-cols-[auto_1fr_auto] gap-4 items-center"
  >
    <!-- Logo -->
    <a href="/" title="Endigo Design">
      <img class="w-15 anim-cube-spin" src="/logo.png" alt="Endigo Design" />
    </a>
    <!-- Navigation -->
    {
      pathname.includes("/works") ? (
        // Go Back
        <nav>
          <a class="hover:no-underline" href="/">
            &larr; Go Back
          </a>
        </nav>
      ) : (
        // Browse
        <nav class="flex gap-4">
          {links.map((link) => (
            <a href={link.href} class={`${setActiveClass(link)}`}>
              {link.label}
            </a>
          ))}
        </nav>
      )
    }

    <!-- Contact -->
    <a class="btn preset-filled" href="mailto:chris@skeleton.dev">Let's Talk</a>
  </div>
</header>
