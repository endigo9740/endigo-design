---
// Based on: https://daisyui.com/components/hover-3d

import { Image } from "astro:assets";

interface Props {
  href: string;
  src: string;
  alt: string;
  title: string;
  accent?: string;
  transitionName?: string;
  workId?: string;
}

const { href, src, alt, title, accent, transitionName, workId } = Astro.props;
---

<a href={href} data-work-id={workId} class="scroll-mt-24">
  <figure class="space-y-2">
    <!-- 3D hover card (image only) -->
    <div class="hover-3d w-full">
      <!-- Visible face -->
      <div class="rounded-xl shadow-xl">
        <Image
          src={src}
          alt={alt}
          width={300}
          height={300}
          class="block w-full aspect-square rounded-xl"
          style={{ backgroundColor: accent }}
          transition:name={transitionName}
        />
      </div>
      <!-- 8 hover zones that drive the tilt -->
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
      <div></div>
    </div>
    <strong class="block text-center md:text-xl">
      {title}
    </strong>
  </figure>
</a>

<style>
  .hover-3d {
    display: grid;
    perspective: 75rem;
    --transform: 0, 0;
    --shine: 100% 100%;
    --shadow: 0rem 0rem 0rem;
    --ease: linear(
      0,
      0.931 13.8%,
      1.196 21.4%,
      1.343 29.8%,
      1.378 36%,
      1.365 43.2%,
      1.059 78%,
      1
    );
  }

  /*
   * Shadow as a compositor-only layer.
   * Replaces an animated `filter: drop-shadow()` stack (which repainted every
   * frame) with a static box-shadow revealed via opacity + translate — both
   * run on the GPU compositor with no per-frame repaint.
   */
  .hover-3d::after {
    content: "";
    grid-area: 1 / 1 / 4 / 4;
    z-index: -1;
    pointer-events: none;
    border-radius: 0.75rem; /* matches rounded-xl on the face */
    opacity: 0;
    box-shadow:
      0 0 0.1rem #00000003,
      0 0 0.2rem #00000003,
      0 0 0.3rem #00000003,
      0 0 0.4rem #00000003;
    translate: var(--shadow);
    transition:
      opacity ease-out 400ms,
      translate ease-out 400ms;
  }

  .hover-3d:hover::after {
    opacity: 1;
  }

  .hover-3d > :nth-child(n + 2) {
    isolation: isolate;
    z-index: 1;
    scale: 1.2;
  }

  .hover-3d > :first-child {
    overflow: hidden;
    grid-area: 1 / 1 / 4 / 4;
    transform: rotate3d(var(--transform), 0, 10deg);
    transition:
      transform var(--ease) 500ms,
      scale var(--ease) 500ms,
      outline-color ease-out 500ms;
    outline: 0.5px solid #0000;
    outline-offset: -1px;
  }

  .hover-3d > :first-child::before {
    content: "";
    width: 33.3333%;
    height: 33.3333%;
    pointer-events: none;
    position: absolute;
    z-index: 1;
    scale: 500%;
    opacity: 0;
    filter: blur(0.75rem);
    background-image: radial-gradient(
      circle at 50%,
      #fff3 10%,
      transparent 50%
    );
    translate: var(--shine);
    transition:
      translate ease-out 400ms,
      opacity ease-out 400ms;
  }

  .hover-3d:hover {
    --ease: linear(
      0,
      0.708 15.2%,
      0.927 23.6%,
      1.067 33%,
      1.12 41%,
      1.13 50.2%,
      1.019 83.2%,
      1
    );
  }

  .hover-3d:hover > :first-child {
    outline-color: #fff1;
    scale: 1.05;
  }

  .hover-3d:hover > :first-child::before {
    opacity: 1;
  }

  .hover-3d > :nth-child(2) {
    grid-area: 1 / 1 / 2 / 2;
  }
  .hover-3d > :nth-child(3) {
    grid-area: 1 / 2 / 2 / 3;
  }
  .hover-3d > :nth-child(4) {
    grid-area: 1 / 3 / 2 / 4;
  }
  .hover-3d > :nth-child(5) {
    grid-area: 2 / 1 / 3 / 2;
  }
  .hover-3d > :nth-child(6) {
    grid-area: 2 / 3 / 3 / 4;
  }
  .hover-3d > :nth-child(7) {
    grid-area: 3 / 1 / 4 / 2;
  }
  .hover-3d > :nth-child(8) {
    grid-area: 3 / 2 / 4 / 3;
  }
  .hover-3d > :nth-child(9) {
    grid-area: 3 / 3 / 4 / 4;
  }

  .hover-3d:has(> :nth-child(2):hover) {
    --transform: -1, 1;
    --shine: 0% 0%;
    --shadow: -0.5rem -0.5rem;
  }
  .hover-3d:has(> :nth-child(3):hover) {
    --transform: -1, 0;
    --shine: 100% 0%;
    --shadow: 0rem -0.5rem;
  }
  .hover-3d:has(> :nth-child(4):hover) {
    --transform: -1, -1;
    --shine: 200% 0%;
    --shadow: 0.5rem -0.5rem;
  }
  .hover-3d:has(> :nth-child(5):hover) {
    --transform: 0, 1;
    --shine: 0% 100%;
    --shadow: -0.5rem 0rem;
  }
  .hover-3d:has(> :nth-child(6):hover) {
    --transform: 0, -1;
    --shine: 200% 100%;
    --shadow: 0.5rem 0rem;
  }
  .hover-3d:has(> :nth-child(7):hover) {
    --transform: 1, 1;
    --shine: 0% 200%;
    --shadow: -0.5rem 0.5rem;
  }
  .hover-3d:has(> :nth-child(8):hover) {
    --transform: 1, 0;
    --shine: 100% 200%;
    --shadow: 0rem 0.5rem;
  }
  .hover-3d:has(> :nth-child(9):hover) {
    --transform: 1, -1;
    --shine: 200% 200%;
    --shadow: 0.5rem 0.5rem;
  }

  /*
   * Respect reduced-motion: Here we remove the spatial motion entirely so the
   * card stays put — the shine/shadow/outline still reveal (no motion),
   * just without the 3D tilt, scale, or positional drift.
   */
  @media (prefers-reduced-motion: reduce) {
    .hover-3d > :first-child,
    .hover-3d:hover > :first-child {
      transform: none;
      scale: 1;
    }

    .hover-3d > :first-child::before,
    .hover-3d::after {
      translate: none;
    }
  }
</style>
